{
  "configurations": [
    {
      "name": "ROS2-Humble",
      "intelliSenseMode": "gcc-x64",
      "compilerPath": "/usr/bin/gcc",

      "cStandard": "gnu11",
      "cppStandard": "c++17",

      "includePath": [
        "${workspaceFolder}/src/**",
        "${workspaceFolder}/build/**",
        "${workspaceFolder}/install/**",
        "/opt/ros/humble/include/**",
        "/usr/include/**",
        "/usr/include/eigen3"
      ],

      "defines": [
        "ROS_DISTRO_HUMBLE"
      ],

      "browse": {
        "path": [
          "${workspaceFolder}/src",
          "${workspaceFolder}/install",
          "/opt/ros/humble/include",
          "/usr/include",
          "/usr/include/eigen3"
        ],
        "limitSymbolsToIncludedHeaders": false
      }
    }
  ],
  "version": 4
}